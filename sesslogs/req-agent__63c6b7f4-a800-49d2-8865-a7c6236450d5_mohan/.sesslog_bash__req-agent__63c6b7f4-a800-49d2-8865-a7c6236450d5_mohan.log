doc.close()
PYEOF }
[[2026-04-12 23:07:59]] {Bash: source .venv/bin/activate && python3 << 'PYEOF'
import fitz
from collections import Counter

doc = fitz.open("data/raw/vzw/2026_feb/requirements/LTEDATARETRY.pdf")

# Collect all unique font size + bold combinations and their frequency
font_combos = Counter()
heading_samples = {}  # (size, bold) -> sample texts

for page_num in range(len(doc)):
    page = doc[page_num]
    blocks = page.get_text("dict")["blocks"]
    for b in blocks:
        if b["type"] != 0:
            continue
        for line in b["lines"]:
            for span in line["spans"]:
                text = span["text"].strip()
                if not text:
                    continue
                size = round(span["size"], 1)
                bold = bool(span["flags"] & 2**4)
                key = (size, bold)
                font_combos[key] += 1
                # Collect samples for non-body text
                if key not in heading_samples:
                    heading_samples[key] = []
                if len(heading_samples[key]) < 3 and len(text) > 3:
                    heading_samples[key].append(f"p{page_num+1}: {text[:80]}")

print("Font size distribution (size, bold) -> count:")
for (size, bold), count in sorted(font_combos.items()):
    boldstr = "BOLD" if bold else "    "
    print(f"  {size:6.1f} {boldstr}: {count:6d}  samples: {heading_samples.get((size, bold), [''])[:2]}")

# Check image count
total_images = 0
for page_num in range(len(doc)):
    images = doc[page_num].get_images()
    total_images += len(images)
print(f"\nTotal images: {total_images}")

doc.close()
PYEOF }
