[[2026-04-13 13:34:44]] {Bash: PYTHONPATH=. .venv/bin/python -c "
import json
from pathlib import Path

# Show samples of each cross-ref type
tree = json.loads(Path('data/parsed/LTEB13NAC_tree.json').read_text())

# Sample with standards refs
for r in tree['requirements']:
    xr = r.get('cross_references', {})
    if xr.get('standards'):
        print('=== Sample with standards refs ===')
        print(f'  Section: {r[\"section_number\"]} {r[\"title\"]}')
        print(f'  Req ID: {r[\"req_id\"]}')
        for s in xr['standards'][:3]:
            print(f'  -> {s[\"spec\"]} section {s[\"section\"]} {s[\"release\"]}')
        break

# Sample with external plan refs
for r in tree['requirements']:
    xr = r.get('cross_references', {})
    if xr.get('external_plans'):
        print('\\n=== Sample with external plan refs ===')
        print(f'  Section: {r[\"section_number\"]} {r[\"title\"]}')
        print(f'  Req ID: {r[\"req_id\"]}')
        print(f'  External plans: {xr[\"external_plans\"]}')
        print(f'  Internal refs: {xr[\"internal\"][:3]}')
        break

# Sample with internal refs only
for r in tree['requirements']:
    xr = r.get('cross_references', {})
    if xr.get('internal') and not xr.get('external_plans') and not xr.get('standards'):
        print('\\n=== Sample with internal refs only ===')
        print(f'  Section: {r[\"section_number\"]} {r[\"title\"]}')
        print(f'  Internal refs: {xr[\"internal\"][:5]}')
        break

# Standards releases from the document
print(f'\\n=== Referenced standards releases (doc-level) ===')
for spec, rel in list(tree['referenced_standards_releases'].items())[:5]:
    print(f'  {spec} -> {rel}')
print(f'  ... ({len(tree[\"referenced_standards_releases\"])} total)')
"
 }
