[[2026-04-13 14:49:55]] {Bash: python -c "
import json, glob
from collections import Counter

all_specs = Counter()
all_sections = []
releases_seen = set()

for f in sorted(glob.glob('data/resolved/*_xrefs.json')):
    with open(f) as fh:
        m = json.load(fh)
    plan = m['plan_id']
    for ref in m.get('standards_refs', []):
        spec = ref['spec']
        sec = ref.get('section', '')
        rel = ref.get('release', '')
        status = ref['status']
        all_specs[spec] += 1
        if rel:
            releases_seen.add(rel)
        all_sections.append((spec, sec, rel, status, plan))

print('=== Unique specs referenced ===')
for spec, count in all_specs.most_common():
    print(f'  {spec}: {count} references')

print(f'\n=== Releases seen ===')
for r in sorted(releases_seen):
    print(f'  {r}')

print(f'\n=== Sample references with sections ===')
with_sec = [(s, sec, r, st, p) for s, sec, r, st, p in all_sections if sec]
for spec, sec, rel, status, plan in with_sec[:15]:
    print(f'  {plan}: 3GPP TS {spec} s{sec} rel={rel} [{status}]')

print(f'\n=== Unresolved (no release) ===')
unresolved = [(s, sec, p) for s, sec, r, st, p in all_sections if st == 'unresolved']
for spec, sec, plan in unresolved[:10]:
    print(f'  {plan}: 3GPP TS {spec} sec={sec}')

print(f'\nTotal refs: {len(all_sections)}, unique specs: {len(all_specs)}')
print(f'With section: {len(with_sec)}, releases: {sorted(releases_seen)}')
" 2>&1 }
