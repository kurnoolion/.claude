# Check req IDs are captured
import re
req_id_blocks = [b for b in test_ir.content_blocks if re.search(r"VZ_REQ_\w+_\d+", b.text)]
print(f"Blocks containing VZ_REQ IDs: {len(req_id_blocks)}")
PYEOF }
