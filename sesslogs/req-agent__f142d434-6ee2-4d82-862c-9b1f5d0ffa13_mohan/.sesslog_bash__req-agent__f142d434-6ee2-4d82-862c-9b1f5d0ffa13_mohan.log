    if m.get('cross_plan'):
        targets = set()
        for ref in m['cross_plan']:
            if ref.get('target_plan_id'):
                targets.add(ref['target_plan_id'])
        if targets:
            print(f'  Cross-plan targets: {sorted(targets)}')
    print()
" 2>&1 }
