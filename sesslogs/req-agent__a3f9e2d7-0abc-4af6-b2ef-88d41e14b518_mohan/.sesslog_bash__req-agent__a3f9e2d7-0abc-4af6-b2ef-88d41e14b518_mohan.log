import docx, re
doc = docx.Document('data/standards/TS_24.301/Rel-11/24301-be0.docx')

# Analyze heading structure
sec_pat = re.compile(r'^([\d]+(?:\.[\d]+)*[A-Za-z]?)\t(.*)$')
annex_pat = re.compile(r'^(Annex\s+[A-Z])\s*[\(:]\s*(.*)$', re.IGNORECASE)

print('--- Section headings with styles (first 50) ---')
count = 0
for p in doc.paragraphs:
    if not p.style.name.startswith('Heading'):
        continue
    text = p.text.strip()
    if not text:
        continue

    level = p.style.name  # e.g. 'Heading 1', 'Heading 2'
    m = sec_pat.match(text)
    am = annex_pat.match(text)
    if m:
        sec_num, title = m.group(1), m.group(2).strip()
        print(f'  [{level}] {sec_num} → {title[:80]}')
    elif am:
        annex_id, title = am.group(1), am.group(2).strip()
        print(f'  [{level}] {annex_id} → {title[:80]}')
    else:
        print(f'  [{level}] (no number) → {text[:80]}')
    count += 1
    if count >= 50:
        print(f'  ... (more headings follow)')
        break

# Count total headings
total = sum(1 for p in doc.paragraphs if p.style.name.startswith('Heading') and p.text.strip())
print(f'\nTotal headings: {total}')

# Check section 5.5.1.2.5 specifically (referenced in our docs)
print('\n--- Looking for section 5.5.1.2.5 ---')
found = False
for i, p in enumerate(doc.paragraphs):
    if '5.5.1.2.5' in p.text:
        text = p.text.strip()
        print(f'  Para {i} [{p.style.name}]: {text[:120]}')
        found = True
        # Show next 3 paragraphs for context
        for j in range(1, 4):
            if i+j < len(doc.paragraphs):
                p2 = doc.paragraphs[i+j]
                print(f'    +{j} [{p2.style.name}]: {p2.text.strip()[:100]}')
        break
if not found:
    print('  Not found')
" 2>&1 }
