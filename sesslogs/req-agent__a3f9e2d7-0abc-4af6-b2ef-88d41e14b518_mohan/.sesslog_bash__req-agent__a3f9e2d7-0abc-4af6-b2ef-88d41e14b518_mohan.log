import json
from pathlib import Path

for f in sorted(Path('data/parsed').glob('*_tree.json')):
    tree = json.loads(f.read_text())
    reqs = tree['requirements']
    
    internal_refs = 0
    external_plans = set()
    std_refs = 0
    reqs_with_xrefs = 0
    
    for r in reqs:
        xr = r.get('cross_references', {})
        has_any = False
        internal = xr.get('internal', [])
        external = xr.get('external_plans', [])
        standards = xr.get('standards', [])
        
        internal_refs += len(internal)
        external_plans.update(external)
        std_refs += len(standards)
        if internal or external or standards:
            has_any = True
            reqs_with_xrefs += 1
    
    print(f'{tree[\"plan_id\"]:20s}  reqs={len(reqs):4d}  '
          f'w/xrefs={reqs_with_xrefs:3d}  '
          f'internal={internal_refs:4d}  '
          f'ext_plans={sorted(external_plans)}  '
          f'std_refs={std_refs:4d}  '
          f'std_releases={len(tree.get(\"referenced_standards_releases\", {}))}')
"
 }
