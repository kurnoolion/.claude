# Inventory of all available data for graph construction
from pathlib import Path
import json

print('=== Available Data for KG Construction ===')
print()

# Parsed trees (requirements)
trees = sorted(Path('data/parsed').glob('*_tree.json'))
print(f'Parsed requirement trees: {len(trees)}')
for t in trees:
    with open(t) as f:
        d = json.load(f)
    print(f'  {d[\"plan_id\"]}: {len(d[\"requirements\"])} reqs, MNO={d.get(\"mno\",\"\")}, rel={d.get(\"release\",\"\")}')

# Resolved cross-refs
xrefs = sorted(Path('data/resolved').glob('*_xrefs.json'))
print(f'\nCross-reference manifests: {len(xrefs)}')
for x in xrefs:
    with open(x) as f:
        d = json.load(f)
    s = d['summary']
    print(f'  {d[\"plan_id\"]}: int={s[\"total_internal\"]}, xplan={s[\"total_cross_plan\"]}, std={s[\"total_standards\"]}')

# Feature taxonomy
print(f'\nFeature taxonomy:')
with open('data/taxonomy/taxonomy.json') as f:
    tax = json.load(f)
print(f'  Features: {len(tax[\"features\"])}')
print(f'  Source docs: {tax[\"source_documents\"]}')

# Standards
stds_index = Path('data/standards/reference_index.json')
if stds_index.exists():
    with open(stds_index) as f:
        idx = json.load(f)
    parsed_specs = list(Path('data/standards').glob('*/*/spec_parsed.json'))
    print(f'\nStandards:')
    print(f'  Reference index: {idx[\"total_unique_specs\"]} specs, {len(idx[\"specs\"])} spec-release pairs')
    print(f'  Parsed specs: {len(parsed_specs)}')
    for p in sorted(parsed_specs):
        with open(p) as f:
            s = json.load(f)
        print(f'    TS {s[\"spec_number\"]} {s[\"release\"]}: {len(s[\"sections\"])} sections')
" 2>&1 }
