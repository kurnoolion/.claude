    if matches:
        print(f'\n--- \"{kw}\" ({len(matches)} matches) ---')
        for plan, sec, rid, title in matches[:5]:
            print(f'  {plan} {sec} [{rid}] {title}')
        if len(matches) > 5:
            print(f'  ... +{len(matches)-5} more')
