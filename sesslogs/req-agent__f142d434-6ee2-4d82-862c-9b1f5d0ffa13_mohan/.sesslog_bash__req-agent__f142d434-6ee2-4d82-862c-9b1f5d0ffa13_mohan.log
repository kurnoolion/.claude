for r in plans['LTEDATARETRY']['requirements']:
    if 't3402' in (r.get('title','') + r.get('body_text','')).lower():
        print(f'{r[\"section_number\"]} [{r[\"req_id\"]}] {r[\"title\"][:80]}')
        body = r.get('body_text','')[:200]
        if body: print(f'  Body: {body}')

print()
# Q2: Generic throttling algorithm - single doc
