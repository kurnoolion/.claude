[[2026-04-13 15:26:15]] {Bash: python -c "
import json, re, glob
from collections import defaultdict

# All patterns for section-level 3GPP references
patterns = [
    # 'TS 24.301, section 5.5.3.2.5'  or  'TS 24.301 section 5.5.3'
    re.compile(r'(?:3GPP\s+)?TS\s+(\d[\d.]*\d)\s*,?\s*(?:[Ss]ection|[Cc]lause|§)\s+([\d]+(?:\.[\d]+)*)'),
    # 'section 5.5.1.2.5 of 3GPP TS 24.301'  or  'clause 5.1 of TS 24.301'
    re.compile(r'(?:[Ss]ection|[Cc]lause|§)\s+([\d]+(?:\.[\d]+)*)\s+of\s+(?:3GPP\s+)?TS\s+(\d[\d.]*\d)'),
    # 'TS 24.301 [5] section 5.5.3' (with reference number)
    re.compile(r'(?:3GPP\s+)?TS\s+(\d[\d.]*\d)\s*(?:\(?\s*(?:reference\s*)?\[[\d]+\]\s*\)?)\s*,?\s*(?:[Ss]ection|[Cc]lause)\s+([\d]+(?:\.[\d]+)*)'),
    # 'per 3GPP TS 24.301 5.5.3' (section number directly after spec)
    re.compile(r'(?:per|as per|see|per )\s+(?:3GPP\s+)?TS\s+(\d[\d.]*\d)\s+([\d]+\.[\d]+(?:\.[\d]+)*)'),
]

results = defaultdict(lambda: defaultdict(set))
total = 0

for f in sorted(glob.glob('data/parsed/*_tree.json')):
    with open(f) as fh:
        tree = json.load(fh)
    plan = tree['plan_id']
    for req in tree['requirements']:
        text = req.get('text', '')
        for p in patterns:
            for m in p.finditer(text):
                groups = m.groups()
                # Patterns 0,2,3 have (spec, section), pattern 1 has (section, spec)
                if p == patterns[1]:
                    section, spec = groups
                else:
                    spec, section = groups
                # Clean trailing dots from section
                section = section.rstrip('.')
                results[plan][(spec, section)] = results[plan].get((spec, section), set()) if isinstance(results[plan][(spec, section)], set) else set()
                results[plan][(spec, section)].add(req['section_number'])
                total += 1

for plan in sorted(results):
    print(f'=== {plan}: {len(results[plan])} unique (spec, section) pairs ===')
    for (spec, sec), reqs in sorted(results[plan].items()):
        print(f'  TS {spec} sec {sec}  (from {len(reqs)} reqs)')

print(f'\nTotal section-level references: {total}')
" 2>&1 }
