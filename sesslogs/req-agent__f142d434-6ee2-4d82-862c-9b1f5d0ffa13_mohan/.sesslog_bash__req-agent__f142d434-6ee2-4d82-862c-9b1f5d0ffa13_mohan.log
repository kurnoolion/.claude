for r in plans['LTEDATARETRY']['requirements']:
    if 'throttl' in (r.get('title','') + r.get('body_text','')).lower() and r['section_number'].startswith('1.3.3'):
        print(f'{r[\"section_number\"]} [{r[\"req_id\"]}] {r[\"title\"][:80]}')
" 2>&1 }
