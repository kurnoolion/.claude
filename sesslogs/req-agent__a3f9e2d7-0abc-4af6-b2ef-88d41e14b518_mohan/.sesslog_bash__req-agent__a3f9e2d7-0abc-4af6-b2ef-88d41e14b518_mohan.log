from pathlib import Path
from src.parser.structural_parser import RequirementTree
from src.resolver.resolver import CrossReferenceResolver

trees = [RequirementTree.load_json(f) for f in sorted(Path('data/parsed').glob('*_tree.json'))]
print(f'Loaded {len(trees)} trees')

resolver = CrossReferenceResolver(trees)
manifests = resolver.resolve_all()

for m in manifests:
    s = m.summary
    print(f'{m.plan_id:20s}  '
          f'internal={s.resolved_internal:3d}/{s.total_internal:3d} (broken={s.broken_internal:2d})  '
          f'xplan={s.resolved_cross_plan}/{s.total_cross_plan} (unresolved={s.unresolved_cross_plan})  '
          f'std={s.resolved_standards:3d}/{s.total_standards:3d} (unresolved={s.unresolved_standards:2d})')
" 2>&1 }
