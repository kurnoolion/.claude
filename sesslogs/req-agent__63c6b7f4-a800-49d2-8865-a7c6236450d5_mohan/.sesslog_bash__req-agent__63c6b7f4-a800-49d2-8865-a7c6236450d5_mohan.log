"""Quick analysis of both representative docs to inform profiler algorithms."""
from pathlib import Path
from collections import Counter
from src.models.document import DocumentIR, BlockType
import re

for name in ["LTEDATARETRY", "LTEB13NAC"]:
    ir = DocumentIR.load_json(Path(f"data/extracted/{name}_ir.json"))
    print(f"\n{'='*60}")
    print(f"{ir.source_file} — {ir.block_count} blocks")
    
    # Font size distribution for text blocks
    font_dist = Counter()
    for b in ir.blocks_by_type(BlockType.PARAGRAPH):
        if b.font_info:
            key = (b.font_info.size, b.font_info.bold)
            font_dist[key] += 1
    
    print("\nFont distribution (size, bold) -> count:")
    for (size, bold), count in sorted(font_dist.items(), key=lambda x: -x[1])[:10]:
        print(f"  {size:5.1f} {'BOLD' if bold else '    '}: {count:5d}")
    
    # Section number patterns in heading-sized text
    heading_blocks = [b for b in ir.blocks_by_type(BlockType.PARAGRAPH) 
                     if b.font_info and b.font_info.size >= 13]
    section_nums = []
    for b in heading_blocks:
        m = re.match(r'^((?:\d+\.)+\d*)\s', b.text)
        if m:
            section_nums.append(m.group(1))
    if section_nums:
        depths = [s.count('.') + 1 for s in section_nums if not s.endswith('.')]
        print(f"\nSection numbers found: {len(section_nums)}, max depth: {max(depths) if depths else 0}")
        print(f"  Samples: {section_nums[:5]}")
    
    # Requirement ID patterns
    req_ids = []
    for b in ir.content_blocks:
        found = re.findall(r'VZ_REQ_\w+_\d+', b.text)
        req_ids.extend(found)
    plan_ids = set(re.match(r'VZ_REQ_(\w+)_\d+', rid).group(1) for rid in req_ids if re.match(r'VZ_REQ_(\w+)_\d+', rid))
    print(f"\nReq IDs found: {len(req_ids)}, unique: {len(set(req_ids))}, plan IDs: {plan_ids}")
    
    # First page text (for plan metadata)
    first_page = [b for b in ir.content_blocks if b.position.page == 1 and b.type == BlockType.PARAGRAPH]
    print(f"\nFirst page blocks ({len(first_page)}):")
    for b in first_page[:3]:
        print(f"  [{b.font_info.size}pt] {b.text[:120]}")
    
    # Font families
    families = Counter()
    for b in ir.blocks_by_type(BlockType.PARAGRAPH):
        if b.font_info and b.font_info.font_name:
            families[b.font_info.font_name] += 1
    print(f"\nTop font families: {families.most_common(5)}")
PYEOF }
