import json
with open('data/parsed/LTEDATARETRY_tree.json') as f:
    tree = json.load(f)
# Look at body text for 3GPP references with section numbers
import re
pattern = re.compile(r'3GPP\s+TS\s+(\d[\d.]*\d)\s+[Ss]ection\s+([\d.]+)')
pattern2 = re.compile(r'3GPP\s+TS\s+(\d[\d.]*\d),?\s+[Cc]lause\s+([\d.]+)')
pattern3 = re.compile(r'3GPP\s+TS\s+(\d[\d.]*\d)\s+\[[\d]+\]\s+[Ss]ection\s+([\d.]+)')
# Also look for patterns like '24.301 section 5.5.1'
count = 0
for req in tree['requirements']:
    body = req.get('body_text', '')
    for p in [pattern, pattern2, pattern3]:
        for m in p.finditer(body):
            if count < 20:
                print(f'{req[\"section_number\"]}: {m.group(0)}')
            count += 1
print(f'\nTotal section-level refs found: {count}')
" 2>&1 }
