from pathlib import Path
from src.extraction.registry import extract_document
from src.profiler.profiler import DocumentProfiler
from src.profiler.profile_schema import DocumentProfile
from src.parser.structural_parser import GenericStructuralParser

# Step 1: Extract
pdf = Path('LTEDATARETRY.pdf')
ir = extract_document(pdf, mno='VZW', release='2026_feb', doc_type='requirement')
print(f'Extraction: {ir.block_count} blocks, {ir.page_count} pages')

# Step 2: Profile
profiler = DocumentProfiler()
profile = profiler.create_profile([ir], profile_name='smoke_test')
print(f'Profile: {len(profile.heading_detection.levels)} heading levels')
print(f'  Req ID pattern: {profile.requirement_id.pattern}')
print(f'  H/F patterns: {len(profile.header_footer.header_patterns)} header, {len(profile.header_footer.footer_patterns)} footer')
print(f'  Cross-ref req pattern: {profile.cross_reference_patterns.requirement_id_refs}')

# Step 3: Parse
parser = GenericStructuralParser(profile)
tree = parser.parse(ir)
print(f'Parse: {len(tree.requirements)} requirements')
print(f'  Plan ID: {tree.plan_id}')
print(f'  Standards: {len(tree.referenced_standards_releases)} specs')

# Check for trailing-dot bug
for spec in tree.referenced_standards_releases:
    if spec.endswith('.'):
        print(f'  BUG: trailing dot in spec: {spec}')
if not any(s.endswith('.') for s in tree.referenced_standards_releases):
    print('  No trailing dot bug in spec names')
" 2>&1 | head -40 }
