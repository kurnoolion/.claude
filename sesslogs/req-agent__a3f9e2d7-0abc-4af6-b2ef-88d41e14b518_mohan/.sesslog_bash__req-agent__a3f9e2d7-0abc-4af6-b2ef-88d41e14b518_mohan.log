from pathlib import Path
from src.parser.structural_parser import RequirementTree
from src.resolver.resolver import CrossReferenceResolver, RefStatus

trees = [RequirementTree.load_json(f) for f in sorted(Path('data/parsed').glob('*_tree.json'))]
resolver = CrossReferenceResolver(trees)

# Investigate broken internal refs in LTEDATARETRY
tree = [t for t in trees if t.plan_id == 'LTEDATARETRY'][0]
manifest = resolver.resolve_tree(tree)

print('=== Broken internal refs (LTEDATARETRY, first 5) ===')
broken = [r for r in manifest.internal_refs if r.status == RefStatus.BROKEN]
for r in broken[:5]:
    print(f'  {r.source_section} ({r.source_req_id}) -> {r.target_req_id}')

# Check if broken refs are actually self-references
print(f'\\nTotal broken: {len(broken)}')
self_refs = [r for r in broken if r.target_req_id == r.source_req_id]
print(f'Self-references: {len(self_refs)}')

# Check if broken refs exist in other plans
in_other = [r for r in broken if any(r.target_req_id == req.req_id for t in trees for req in t.requirements if t.plan_id != tree.plan_id)]
print(f'Actually in other plans: {len(in_other)}')

# The rest — truly missing
truly_broken = [r for r in broken if r not in self_refs and r not in in_other]
print(f'Truly missing from corpus: {len(truly_broken)}')
for r in truly_broken[:5]:
    print(f'  {r.source_section} -> {r.target_req_id}')
" 2>&1 }
