import json
from pathlib import Path

plans = {}
for tree_path in sorted(Path('data/parsed').glob('*_tree.json')):
    with open(tree_path) as f:
        tree = json.load(f)
    plans[tree['plan_id']] = tree

# SMS over IMS - cross-doc (LTESMS + LTEB13NAC)
print('=== SMS over IMS (cross-doc) ===')
for pid in ['LTESMS', 'LTEB13NAC']:
    for r in plans[pid]['requirements']:
        if 'sms over ims' in (r.get('title','') + r.get('body_text','')).lower():
            print(f'{pid} {r[\"section_number\"]} [{r[\"req_id\"]}] {r[\"title\"][:80]}')

print()
# PDN connectivity - cross-doc (LTEB13NAC + LTEDATARETRY)
print('=== PDN connectivity (cross-doc) ===')
for pid in ['LTEB13NAC', 'LTEDATARETRY']:
    count = 0
    for r in plans[pid]['requirements']:
        if 'pdn connect' in (r.get('title','') + r.get('body_text','')).lower():
            if count < 3:
                print(f'{pid} {r[\"section_number\"]} [{r[\"req_id\"]}] {r[\"title\"][:80]}')
            count += 1
    if count > 3:
        print(f'  ... +{count-3} more in {pid}')

print()
# IMS registration - cross-doc (LTEB13NAC primary, others ref)
print('=== IMS registration (cross-doc) ===')
for pid in ['LTEB13NAC', 'LTESMS', 'LTEDATARETRY']:
    count = 0
    for r in plans[pid]['requirements']:
        if 'ims registr' in (r.get('title','') + r.get('body_text','')).lower():
            if count < 2:
                print(f'{pid} {r[\"section_number\"]} [{r[\"req_id\"]}] {r[\"title\"][:80]}')
            count += 1
    if count > 2:
        print(f'  ... +{count-2} more in {pid}')

print()
# Attach reject cause codes - for standards comparison
print('=== Attach reject + cause codes ===')
for r in plans['LTEDATARETRY']['requirements']:
    if 'attach reject' in (r.get('title','') + r.get('body_text','')).lower():
        stds = r.get('cross_references',{}).get('standards',[])
        std_str = ', '.join(f'{s[\"spec\"]} s{s.get(\"section\",\"?\")}' for s in stds[:3]) if stds else 'none'
        print(f'{r[\"section_number\"]} [{r[\"req_id\"]}] {r[\"title\"][:70]} (stds: {std_str})')
" 2>&1 }
