#!/bin/bash
# ============================================================
# Merge C:\.claude into D:\.claude, then set up symlinks
# Run this from WSL
# ============================================================

set -euo pipefail

C_CLAUDE="/mnt/c/Users/Mohan Reddy Duggi/.claude"
D_CLAUDE="/mnt/d/.claude"

echo "=== Step 1: Copy project folders from C: into D: ==="
cp -r "$C_CLAUDE/projects/D--trading-gex-vex-dashboard"       "$D_CLAUDE/projects/"
cp -r "$C_CLAUDE/projects/C--Users-Mohan-Reddy-Duggi"         "$D_CLAUDE/projects/"
cp -r "$C_CLAUDE/projects/D--work-fastmemory-VZW-OA-Feb2026"  "$D_CLAUDE/projects/"
cp -r "$C_CLAUDE/projects/D--work-general"                     "$D_CLAUDE/projects/"
echo "  Done."

echo "=== Step 2: Copy file-history and plans from C: ==="
cp -rn "$C_CLAUDE/file-history" "$D_CLAUDE/" 2>/dev/null || true
cp -rn "$C_CLAUDE/plans"        "$D_CLAUDE/" 2>/dev/null || true
echo "  Done."

echo "=== Step 3: Rename project folders to Linux-encoded paths ==="
cd "$D_CLAUDE/projects"

# From C: (Windows-encoded)
mv "D--trading-gex-vex-dashboard"       "home-mohan-trading-gex-vex-dashboard"
mv "C--Users-Mohan-Reddy-Duggi"        "home-mohan"
mv "D--work-fastmemory-VZW-OA-Feb2026" "home-mohan-work-fastmemory-VZW-OA-Feb2026"
mv "D--work-general"                    "home-mohan-work-general"

# From D: (WSL /mnt/d encoded — note the leading dash)
mv -- "-mnt-d-work-req-agent"           "home-mohan-work-req-agent"
mv -- "-mnt-d-work-prompts"             "home-mohan-work-prompts"
echo "  Done."

echo "=== Step 4: Merge settings.json ==="
cat > "$D_CLAUDE/settings.json" << 'SETTINGS'
{
  "model": "claude-opus-4-6",
  "autoUpdatesChannel": "latest",
  "enabledPlugins": {
    "session-logger@dazzle-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "dazzle-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "DazzleML/claude-session-logger"
      }
    }
  },
  "effortLevel": "high"
}
SETTINGS
echo "  Done."

echo "=== Step 5: Fix hardcoded paths in memory files ==="
find "$D_CLAUDE/projects" -name '*.md' -exec sed -i \
  -e 's|D:/work|/home/mohan/work|g' \
  -e 's|D:\\work|/home/mohan/work|g' \
  -e 's|/mnt/d/work|/home/mohan/work|g' \
  -e 's|D:/trading|/home/mohan/trading|g' \
  -e 's|/mnt/d/trading|/home/mohan/trading|g' \
  {} +
echo "  Done."

echo "=== Step 6: Create WSL symlink ~/.claude -> /mnt/d/.claude ==="
if [ -L /home/mohan/.claude ]; then
  echo "  Symlink already exists, removing old one."
  rm /home/mohan/.claude
elif [ -d /home/mohan/.claude ]; then
  echo "  WARNING: /home/mohan/.claude is a real directory, not a symlink."
  echo "  Back it up and remove it manually, then re-run this step."
  echo "  Skipping symlink creation."
  exit 1
fi
ln -s /mnt/d/.claude /home/mohan/.claude
echo "  Done."

echo ""
echo "=== Verification ==="
echo "Projects:"
ls "$D_CLAUDE/projects/"
echo ""
echo "Symlink:"
ls -la /home/mohan/.claude
echo ""
echo "=== All done! ==="
echo ""
echo "NEXT STEPS (manual):"
echo "  1. From an elevated Windows cmd.exe, replace C:\\.claude with a symlink to D:\\.claude:"
echo "     rmdir /s /q \"C:\\Users\\Mohan Reddy Duggi\\.claude\""
echo "     mklink /D \"C:\\Users\\Mohan Reddy Duggi\\.claude\" \"D:\\.claude\""
echo ""
echo "  2. If you have a /mnt/d/trading directory, symlink it too:"
echo "     ln -s /mnt/d/trading /home/mohan/trading"
echo ""
echo "  3. Set up git for syncing (from WSL):"
echo "     cd /mnt/d/.claude"
echo "     git init"
echo "     # Create .gitignore (see below), then git add . && git commit"
