{
  "model": "claude-opus-4-6",
  "autoUpdatesChannel": "latest",
  "enabledPlugins": {
    "session-logger@dazzle-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "dazzle-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "DazzleML/claude-session-logger"
      }
    }
  },
  "effortLevel": "high",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$PWD\" in /home/mohan*) ;; *) echo 'Error: cwd must be under /home/mohan, got '\"$PWD\" >&2; exit 1;; esac",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/sync-claude-to-git.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/extract-knowledge.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session-to-markdown.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
