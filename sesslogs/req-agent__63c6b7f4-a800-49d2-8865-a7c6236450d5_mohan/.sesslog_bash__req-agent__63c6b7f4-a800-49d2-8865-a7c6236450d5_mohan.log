import logging
from pathlib import Path

logging.basicConfig(level=logging.INFO, format="%(levelname)s: %(message)s")

from src.extraction.pdf_extractor import PDFExtractor

extractor = PDFExtractor()
ir = extractor.extract(
    Path("data/raw/vzw/2026_feb/requirements/LTEDATARETRY.pdf"),
    mno="VZW",
    release="2026_Feb",
    doc_type="requirement",
)

print(f"\nSource: {ir.source_file}")
print(f"Format: {ir.source_format}")
print(f"Total blocks: {ir.block_count}")
print(f"  Paragraphs: {len(ir.blocks_by_type('paragraph'))}")
print(f"  Tables: {len(ir.blocks_by_type('table'))}")
print(f"  Images: {len(ir.blocks_by_type('image'))}")

# Show first 15 content blocks
print("\n--- First 15 blocks ---")
for b in ir.content_blocks[:15]:
    fi = f" [{b.font_info.size}pt {'B' if b.font_info.bold else ' '}]" if b.font_info else ""
    if b.type.value == "paragraph":
        print(f"  [{b.position.page:3d}] {b.type.value:10s}{fi} {b.text[:100]}")
    elif b.type.value == "table":
        print(f"  [{b.position.page:3d}] table       headers={b.headers[:3]}... ({len(b.rows)} rows)")
    elif b.type.value == "image":
        print(f"  [{b.position.page:3d}] image       {b.image_path}")

# Show blocks from page 21 (section 1.3.3)
print("\n--- Page 21 blocks ---")
for b in ir.content_blocks:
    if b.position.page == 21:
        fi = f" [{b.font_info.size}pt {'B' if b.font_info.bold else ' '}]" if b.font_info else ""
        if b.type.value == "paragraph":
            print(f"  [{b.position.index:4d}] {b.type.value:10s}{fi} {b.text[:120]}")
        elif b.type.value == "table":
            print(f"  [{b.position.index:4d}] table       headers={b.headers[:4]} ({len(b.rows)} rows)")
        elif b.type.value == "image":
            print(f"  [{b.position.index:4d}] image       {b.image_path}")
PYEOF }
